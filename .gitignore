# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database scripts and dumps
car_booking_database_structure.sql
*.sql
*.dump
*.tar.gz

# backups
backup-auto/

# playwright mcp screenshots
.playwright-mcp/

# K3s secrets (NEVER commit!)
k3s-manifests/01-secrets.yaml
k3s-manifests/*-secrets.yaml
*.secret.yaml

# K3s generated files (NEVER commit!)
k3s-manifests/*.generated

# IDE and AI tools
.vscode/
.serena/
.claude/

/src/generated/prisma
