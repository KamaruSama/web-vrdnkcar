    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.3.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
