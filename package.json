    "@tailwindcss/forms": "^0.5.11",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.19",
    "dotenv": "^16.6.1",
    "framer-motion": "^11.0.23",
    "lucide-react": "^0.577.0",
    "next": "^15.5.13",
    "next-auth": "^4.24.13",
    "prisma": "^7.5.0",
    "react": "^19.2.4",
    "react-datepicker": "^8.10.0",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.6",
