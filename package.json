{
  "name": "web_vrdnkcar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate && prisma db push --skip-generate",
    "dev": "next dev --turbopack",
    "prestart": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:check": "prisma db push --skip-generate",
